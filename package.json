{
  "name": "b2",
  "version": "1.0.1",
  "private": true,
  "description": "Upload, download, sync, copy, and manage Backblaze B2 Cloud Storage from GitHub Actions. Built on @backblaze-labs/b2-sdk.",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check --error-on-warnings .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "all": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm spellcheck",
    "verify-dist": "pnpm build && git diff --exit-code dist",
    "preversion": "pnpm lint && pnpm typecheck && pnpm test",
    "version": "node scripts/cut-changelog.mjs && pnpm build && git add CHANGELOG.md dist",
    "audit": "pnpm audit --prod --audit-level high",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "docs:check-action-yml": "node scripts/check-action-yml-vs-readme.mjs",
    "docs:lint": "markdownlint-cli2",
    "docs:links": "node scripts/run-lychee.mjs",
    "spellcheck": "cspell --no-progress --no-must-find-files",
    "prepare": "husky"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/glob": "^0.7.0",
    "@backblaze-labs/b2-sdk": "^0.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.9.0",
    "@vercel/ncc": "^0.38.3",
    "@vitest/coverage-v8": "^4.1.7",
    "cspell": "^10.0.1",
    "husky": "^9.1.7",
    "markdownlint-cli2": "^0.22.0",
    "typedoc": "^0.28.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "keywords": [
    "backblaze",
    "b2",
    "cloud-storage",
    "github-action",
    "ci-cd",
    "upload",
    "download",
    "sync"
  ],
  "author": "Backblaze, Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/backblaze-labs/b2-action"
  }
}
