{
  "name": "b2",
  "version": "0.1.0",
  "private": true,
  "description": "Upload, download, sync, copy, and manage Backblaze B2 Cloud Storage from GitHub Actions. Built on @backblaze/b2-sdk.",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check --error-on-warnings .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "all": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "verify-dist": "pnpm build && git diff --exit-code dist",
    "actionlint": "bash scripts/actionlint.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/glob": "^0.5.0",
    "@backblaze/b2-sdk": "link:../b2-typescript-sdk"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^20.14.0",
    "@vercel/ncc": "^0.38.3",
    "@vitest/coverage-v8": "^3.1.0",
    "husky": "^9.1.7",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "keywords": [
    "backblaze",
    "b2",
    "cloud-storage",
    "github-action",
    "ci-cd",
    "upload",
    "download",
    "sync"
  ],
  "author": "Backblaze, Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/backblaze-labs/b2-action"
  }
}
